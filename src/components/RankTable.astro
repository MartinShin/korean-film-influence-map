---
import type { Film } from '../data/types';
import { formatPageRank } from '../lib/data';

interface Props {
  films: Film[];
  metric: 'gold' | 'indegree' | 'pagerank';
  caption: string;
  limit?: number;
}
const { films, metric, caption, limit = 15 } = Astro.props;
const value = (film: Film) => metric === 'gold' ? film.metrics.goldInDegree : metric === 'indegree' ? film.metrics.inDegree : formatPageRank(film.metrics.pageRank);
---

<div class="table-wrap">
  <table>
    <caption>{caption}</caption>
    <thead><tr><th scope="col">순위</th><th scope="col">영화</th><th scope="col">감독·연도</th><th scope="col">{metric === 'gold' ? '감독선언' : metric === 'indegree' ? '피인용' : 'PageRank'}</th><th scope="col">가중 점수</th></tr></thead>
    <tbody>
      {films.slice(0, limit).map((film, index) => (
        <tr>
          <td>{index + 1}</td>
          <td><a href={`/films/${film.id}/`}><strong>{film.titleKo}</strong></a></td>
          <td>{film.director || '감독 정보 없음'} · {film.year}</td>
          <td class="number">{value(film)}</td>
          <td class="number">{film.metrics.weightedInDegree.toFixed(2)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
