---
import { url } from '../../lib/url.ts';
import { topFilms } from '../../lib/site.ts';

interface Props {
  kind: 'gold' | 'inDegree' | 'pagerank' | 'weighted';
  count: number;
  caption: string;
}

const { kind, count, caption } = Astro.props;
const rows = topFilms(kind, count);
const fmt2 = (x: number) => x.toFixed(2);
const fmt5 = (x: number) => x.toFixed(5);
---

<div class="table-wrap">
  <table>
    <caption>{caption}</caption>
    <thead>
      <tr>
        <th class="num" scope="col">#</th>
        <th scope="col">영화</th>
        <th class="num" scope="col">감독 언급</th>
        <th class="num" scope="col">피인용</th>
        <th class="num" scope="col">가중</th>
        <th class="num" scope="col">PageRank</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((f) => (
        <tr>
          <td class="num">{f.rank}</td>
          <td>
            <a href={url(`/films/${f.id}/`)}>{f.titleKo} ({f.year})</a>
            {f.kofa.exactRank !== null && <span class="badge-kofa">KOFA {f.kofa.exactRank}위</span>}
            {f.kofa.selected2024 && f.kofa.exactRank === null && <span class="badge-kofa">KOFA 100선</span>}
          </td>
          <td class="num">{f.metrics?.goldInDegree ?? 0}</td>
          <td class="num">{f.metrics?.inDegree ?? 0}</td>
          <td class="num">{fmt2(f.metrics?.weightedInDegree ?? 0)}</td>
          <td class="num">{fmt5(f.metrics?.pagerank ?? 0)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
