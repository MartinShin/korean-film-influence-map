---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url.ts';
---

<BaseLayout title="페이지 없음" description="요청한 페이지를 찾을 수 없습니다." path="/404/">
  <h1>필름이 끊겼습니다</h1>
  <p class="lede">요청하신 페이지가 없습니다. 주소가 바뀌었거나, 후보 상태의 영화 페이지일 수 있습니다.</p>
  <div class="btn-row">
    <a class="btn" href={url('/')}>홈으로</a>
    <a class="btn" href={url('/films/')}>영화 목록</a>
    <a class="btn" href={url('/rankings/')}>순위</a>
  </div>
</BaseLayout>
