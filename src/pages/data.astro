---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url.ts';
import { manifest } from '../lib/site.ts';

const c = manifest.counts;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: '한국영화 내부 영향 인용 그래프',
  version: manifest.datasetVersion,
  dateModified: manifest.researchDate,
  description: '한국영화 사이의 영향·오마주·리메이크 관계와 근거 출처, 그리고 파생 순위 데이터.',
  distribution: [
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: new URL(url('/data/films.json'), Astro.site).href },
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: new URL(url('/data/edges.json'), Astro.site).href },
    { '@type': 'DataDownload', encodingFormat: 'text/csv', contentUrl: new URL(url('/data/films.csv'), Astro.site).href },
    { '@type': 'DataDownload', encodingFormat: 'text/csv', contentUrl: new URL(url('/data/edges.csv'), Astro.site).href },
  ],
};
---

<BaseLayout
  title="데이터"
  description="한국영화 영향 그래프 공개 데이터 - 영화·관계·순위를 JSON과 CSV로 내려받기."
  path="/data/"
  jsonLd={jsonLd}
>
  <h1>데이터</h1>
  <p class="lede">
    데이터셋 {manifest.datasetVersion} · 연구 기준일 {manifest.researchDate} · 스키마 버전 1 ·
    방법론 버전 {manifest.methodologyVersion}
  </p>

  <ul class="stat-grid">
    <li><span class="num">{c.researchNodes}</span><span class="label">영화 레코드 (공개 {c.publishedNodes})</span></li>
    <li><span class="num">{c.researchEdges}</span><span class="label">관계 레코드 (공개 {c.publishedEdges})</span></li>
    <li><span class="num">{c.candidateEdges}</span><span class="label">검토 후보 (순위 미반영)</span></li>
  </ul>

  <h2>내려받기</h2>
  <div class="btn-row">
    <a class="btn" href={url('/data/films.json')} download>films.json</a>
    <a class="btn" href={url('/data/edges.json')} download>edges.json</a>
    <a class="btn" href={url('/data/rankings.json')} download>rankings.json</a>
    <a class="btn" href={url('/data/films.csv')} download>films.csv</a>
    <a class="btn" href={url('/data/edges.csv')} download>edges.csv</a>
  </div>

  <h2>스키마 요약</h2>
  <h3>영화 (films)</h3>
  <ul>
    <li><code>id</code> - 안정 식별자 (film_0001 형식, 버전 간 유지)</li>
    <li><code>titleKo</code>, <code>year</code>, <code>director</code>, <code>aliases</code></li>
    <li><code>kofa.selected2024</code> - KOFA 한국영화 100선(2024) 선정 여부</li>
    <li><code>kofa.exactRank</code> - 공개된 상위 10편의 순위만 기록, 나머지는 null (임의 순위를 만들지 않는다)</li>
    <li><code>publicStatus</code> - published(공개 그래프 포함) / candidateOnly(후보 관계에만 등장)</li>
    <li><code>metrics</code> - 피인용·감독 언급·가중 점수·PageRank (films.json에 포함)</li>
  </ul>
  <h3>관계 (edges)</h3>
  <ul>
    <li><code>id</code> - 안정 식별자 (edge_0001 형식)</li>
    <li><code>citingFilmId → citedFilmId</code> - 후대 인용 영화 → 선대 피인용 영화</li>
    <li><code>relationType</code> - influence / thematic / homage / reference / parody / visual_influence / remake_official</li>
    <li><code>signal</code> - director_declared / critic / public</li>
    <li><code>confidence</code> - high / medium / low</li>
    <li><code>publicationStatus</code> - published / candidate(위키 단독 근거, 순위 미반영)</li>
    <li><code>evidence.publicExcerpt</code> - 300자 이내 근거 발췌문</li>
    <li><code>sources[].url</code> - 원문 출처</li>
  </ul>

  <h2>라이선스와 인용</h2>
  <ul>
    <li>구조화 데이터(관계·순위·라벨)는 자유롭게 연구·비평 목적으로 재사용할 수 있습니다. 출처로 이 사이트를 표기해 주세요.</li>
    <li>근거 발췌문의 저작권은 각 원문(언론사·평론가)에 있으며, 발췌는 출처 표시를 위한 최소 인용입니다. 재배포 시 원문 링크를 유지해 주세요.</li>
    <li>인용 예: 신호철, “한국영화 영향력 지도 {manifest.datasetVersion}”, {manifest.researchDate}, shinhocheol.com/cinema.</li>
  </ul>

  <h2>오류 제보</h2>
  <p>
    잘못된 관계, 빠진 출처, 더 나은 근거를 알고 계시면
    <a href="https://github.com/MartinShin/korean-film-influence-map/issues" rel="noopener noreferrer" target="_blank">GitHub 이슈</a>로
    알려주세요. 관계 하나 단위로 반박·보강할 수 있게 만드는 것이 이 프로젝트의 목표입니다.
  </p>
</BaseLayout>
