---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Notice from '../../components/common/Notice.astro';
import EdgeList from '../../components/films/EdgeList.astro';
import {
  publishedFilms,
  filmById,
  incomingEdges,
  outgoingEdges,
  rankOf,
  type SiteFilm,
} from '../../lib/site.ts';

export function getStaticPaths() {
  return publishedFilms.map((f) => ({ params: { id: f.id } }));
}

const { id } = Astro.params;
const film = filmById.get(id!) as SiteFilm;
const m = film.metrics!;
const incomingPub = incomingEdges(film.id);
const incomingCand = incomingEdges(film.id, true).filter((e) => e.publicationStatus === 'candidate');
const outgoingPub = outgoingEdges(film.id);
const outgoingCand = outgoingEdges(film.id, true).filter((e) => e.publicationStatus === 'candidate');

const ranks = [
  { label: '감독 직접 언급', value: m.goldInDegree, rank: m.goldInDegree > 0 ? rankOf('gold', film.id) : null },
  { label: '피인용 수', value: m.inDegree, rank: m.inDegree > 0 ? rankOf('inDegree', film.id) : null },
  { label: '가중 영향 점수', value: m.weightedInDegree.toFixed(2), rank: m.weightedInDegree > 0 ? rankOf('weighted', film.id) : null },
  { label: 'PageRank', value: m.pagerank.toFixed(5), rank: rankOf('pagerank', film.id) },
];

const desc = `${film.titleKo}(${film.year}${film.director ? ', ' + film.director : ''})의 영향 관계 - 피인용 ${m.inDegree}건, 감독 직접 언급 ${m.goldInDegree}건. 근거 인용문과 출처 포함.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Movie',
  name: film.titleKo,
  dateCreated: String(film.year),
  ...(film.director ? { director: { '@type': 'Person', name: film.director } } : {}),
};
---

<BaseLayout title={`${film.titleKo} (${film.year})`} description={desc} path={`/films/${film.id}/`} jsonLd={jsonLd}>
  <h1>{film.titleKo} <span style="color:var(--muted);font-size:0.75em">({film.year})</span></h1>
  <p class="meta-line">
    {film.director ? `감독 ${film.director}` : '감독 정보 없음'}
    {film.kofa.selected2024 &&
      (film.kofa.exactRank !== null
        ? ` · KOFA 한국영화 100선 ${film.kofa.exactRank}위 (2024)`
        : ' · KOFA 한국영화 100선 선정 (2024, 세부 순위 없음)')}
  </p>

  <ul class="stat-grid">
    {ranks.map((r) => (
      <li>
        <span class="num">{r.value}</span>
        <span class="label">{r.label}{r.rank ? ` · ${r.rank}위` : ''}</span>
      </li>
    ))}
  </ul>

  <h2>이 영화를 인용·계승한 후대 영화 ({incomingPub.length})</h2>
  <EdgeList edges={incomingPub} direction="incoming" emptyText="아직 확인된 후대 인용이 없습니다. 인용이 없다는 뜻이 아니라, 문서로 확인된 관계가 없다는 뜻입니다." />
  {incomingCand.length > 0 && (
    <>
      <h3>검토 후보 (순위 미반영, {incomingCand.length})</h3>
      <EdgeList edges={incomingCand} direction="incoming" emptyText="" />
    </>
  )}

  <h2>이 영화가 참조한 선대 영화 ({outgoingPub.length})</h2>
  <EdgeList edges={outgoingPub} direction="outgoing" emptyText="확인된 선대 참조가 없습니다." />
  {outgoingCand.length > 0 && (
    <>
      <h3>검토 후보 (순위 미반영, {outgoingCand.length})</h3>
      <EdgeList edges={outgoingCand} direction="outgoing" emptyText="" />
    </>
  )}

  <Notice />
</BaseLayout>
